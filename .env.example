# Copy to .env and fill in. Only GOOGLE_API_KEY is required.

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your-key-here

# --- Optional overrides (sensible defaults are used if unset) ---
# LLM_MODEL=gemini-flash-lite-latest
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# EMBEDDING_DEVICE=cpu

# RETRIEVER_K=8
# RERANK_TOP_K=3
# ANSWER_TEMPERATURE=0.2
# MAX_HISTORY_MESSAGES=6
# LOG_LEVEL=INFO

# Local model dirs (point these at offline copies if you have them)
# EMBEDDING_MODEL=/path/to/all-MiniLM-L6-v2
# RERANKER_MODEL=/path/to/ms-marco-MiniLM-L-6-v2
# DOCLING_MODELS_PATH=/path/to/docling_models
